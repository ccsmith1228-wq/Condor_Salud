# ─── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_JWT_SECRET=              # Required in production for API route auth

# ─── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=https://condorsalud.com
# NEXT_PUBLIC_DEMO_MODE=true
NODE_ENV=development
LOG_LEVEL=debug

# ─── Session / Security ───────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SESSION_ENCRYPTION_KEY=           # 64-char hex string, required in production

# ─── Google OAuth ──────────────────────────────────────────────
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Google Maps ───────────────────────────────────────────────
# GOOGLE_MAPS_API_KEY=              # Server-side (for geolocation proxy)
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=      # Client-side (for static maps)

# ─── Sentry ───────────────────────────────────────────────────
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=condor-salud
# SENTRY_PROJECT=condor-salud

# ─── PostHog (Analytics) ──────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Upstash Redis (Rate Limiting) ────────────────────────────
# UPSTASH_REDIS_URL=
# UPSTASH_REDIS_TOKEN=

# ─── Anthropic (Claude AI for Cora chatbot) ───────────────────
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Twilio (WhatsApp notifications) ──────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=

# ─── Daily.co (Video / Telemedicine) ──────────────────────────
# DAILY_API_KEY=

# ─── MercadoPago (Payments) ───────────────────────────────────
# MP_ACCESS_TOKEN=
# NEXT_PUBLIC_MP_PUBLIC_KEY=

# ─── Resend (Transactional Email) ─────────────────────────────
# RESEND_API_KEY=

# ─── Nubix Cloud (RIS/PACS imaging) ───────────────────────────
# NUBIX_API_URL=
# NUBIX_API_KEY=
# NUBIX_TENANT_ID=

# ─── PAMI API (when available) ────────────────────────────────
# PAMI_API_URL=
# PAMI_API_TOKEN=

# ─── AFIP WSFEV1 (Electronic invoicing) ───────────────────────
# AFIP_CERT_PATH=
# AFIP_KEY_PATH=
# AFIP_CUIT=

# ─── Swiss Medical ────────────────────────────────────────────
# SWISS_MEDICAL_CLIENT_ID=
# SWISS_MEDICAL_CLIENT_SECRET=
