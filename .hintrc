{
  "connector": { "name": "local" },
  "hints": {
    "axe/aria": ["default", {
      "aria-valid-attr-value": "off",
      "aria-required-children": "off"
    }],
    "axe/forms": "default",
    "axe/name-role-value": "default",
    "compat-api/css": ["default", {
      "ignore": ["scrollbar-width", "scrollbar-color"]
    }]
  }
}
